    "    Age, mean (SD)",
    "    Sex, n (\%)",
    "        Female",
    "        Male",
    "Vital signs",
    "    Systolic BP",
    "    Diastolic BP",
    "    Heart rate",
    "Lab values",
    "    Hemoglobin",
    "    Platelets"
