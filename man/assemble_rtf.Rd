\name{assemble_rtf}
\alias{assemble_rtf}
\title{Assemble multiple RTF files into one}
\description{
Concatenates two or more RTF files generated by \code{\link{generate_rtfreport}}
into a single RTF document.  The document header (font table, colour table,
page settings) is taken from the \strong{first} input file; subsequent files
contribute only their section content, separated by \code{\\sect}.

This is the standard way to produce a full TFL package (T14.1.1, T14.2.1, …)
as one deliverable RTF.
}
\usage{assemble_rtf(input_files, output_file, overwrite = FALSE)}
\arguments{
\item{input_files}{Character vector of paths to RTF files to combine.
  Must contain at least 2 elements.  Files are included in order.}
\item{output_file}{Path for the assembled output RTF file.}
\item{overwrite}{Logical; whether to overwrite an existing output file.
  Default \code{FALSE}.}
}
\value{Invisibly returns \code{output_file}.}
\section{Page numbering}{
Page-number fields work correctly across the assembled document when the
header/footer text uses \emph{dynamic} tokens:
\itemize{
  \item \code{\{AUTO_PAGE\}} — per-page number rendered by the RTF viewer.
  \item \code{\{AUTO_TOTAL_PAGES\}} — total-page NUMPAGES field rendered by
    the RTF viewer across all assembled files.
}
The static token \code{\{TOTAL_PAGES\}} reflects only the page count of each
source file and will show the wrong total in the assembled output.
}
\seealso{\code{\link{generate_rtfreport}}, \code{\link{rtf_document}}}
\examples{
\dontrun{
  library(magrittr)

  # Build two reports and assemble them.
  make_report <- function(df, hdr) {
    rtf_document() \%>\%
      rtf_section(page = 1, secinfo = list(header = rtf_header(c(l = hdr)))) \%>\%
      rtf_tables(list(df))
  }

  f1 <- tempfile(fileext = ".rtf")
  f2 <- tempfile(fileext = ".rtf")
  generate_rtfreport(make_report(mtcars[1:3, ], "Table 1"), f1, overwrite = TRUE)
  generate_rtfreport(make_report(mtcars[4:6, ], "Table 2"), f2, overwrite = TRUE)

  out <- tempfile(fileext = ".rtf")
  assemble_rtf(c(f1, f2), out, overwrite = TRUE)
}
}
